{
    "name": "ngwebdconsulting/erp",
    "description": "NGWebD Consulting Pvt. Ltd. — ERP System",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "codeigniter4/framework": "^4.5",
        "dompdf/dompdf": "^2.0",
        "phpoffice/phpspreadsheet": "^2.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9",
        "codeigniter4/devkit": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        },
        "files": [
            "app/Helpers/erp_helper.php"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}
